{
    "name": "docs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "cf-typegen": "wrangler types && mv worker-configuration.d.ts src/",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "deploy": "npm run build && wrangler pages deploy",
        "dev": "vite dev",
        "format": "prettier --write .",
        "generate-social": "tsx scripts/generate-social-images.ts",
        "lint": "prettier --check . && eslint .",
        "lint:fix": "npm run format && eslint . --fix",
        "preview": "vite preview",
        "test": "npm run test:unit -- --run && npm run test:e2e",
        "test:e2e": "playwright test",
        "test:unit": "vitest"
    },
    "dependencies": {
        "@sentry/cloudflare": "^10.39.0",
        "@sentry/sveltekit": "^10.39.0"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260227.0",
        "@eslint/compat": "^2.0.2",
        "@eslint/js": "^10.0.1",
        "@humanspeak/svelte-diff-match-patch": "file:..",
        "@internationalized/date": "^3.11.0",
        "@lucide/svelte": "^0.575.0",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.53.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.0",
        "@tanstack/table-core": "^8.21.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/svelte": "^5.3.1",
        "@types/eslint": "^9.6.1",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "bits-ui": "^2.16.1",
        "clsx": "^2.1.1",
        "embla-carousel-svelte": "^8.6.0",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-svelte": "^3.15.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "formsnap": "^2.0.1",
        "globals": "^17.3.0",
        "jsdom": "^28.1.0",
        "layerchart": "2.0.0-next.43",
        "mdsvex": "^0.12.6",
        "mode-watcher": "^1.1.0",
        "paneforge": "^1.0.2",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-svelte": "^3.5.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "puppeteer": "^24.37.5",
        "svelte": "^5.53.0",
        "svelte-check": "^4.4.3",
        "svelte-sonner": "^1.0.7",
        "sveltekit-superforms": "^2.29.1",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.2.0",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.0",
        "vaul-svelte": "1.0.0-next.7",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    },
    "volta": {
        "node": "22.16.0"
    }
}